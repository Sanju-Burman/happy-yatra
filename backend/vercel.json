{
    "version": 2,
    "functions": {
        "src/app.js": {
            "runtime": "@vercel/node"
        }
    },
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "src/app.js"
        },
        {
            "source": "/(.*)",
            "destination": "src/app.js"
        }
    ]
}